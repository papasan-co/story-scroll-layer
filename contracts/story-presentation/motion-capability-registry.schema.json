{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.onautumn.com/story-presentation/1.2.0/motion-capability-registry.schema.json",
  "title": "MotionCapabilityRegistryV1",
  "type": "object",
  "properties": {
    "contract": { "const": "MotionCapabilityRegistry.v1" },
    "version": { "const": "1.1.0" },
    "profileDeclarations": {
      "type": "object",
      "properties": {
        "story": { "const": "populated" },
        "website": { "const": "declared_empty" },
        "social": { "const": "declared_empty" }
      },
      "required": ["story", "website", "social"],
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*\\.v[1-9][0-9]*$" },
          "executor": { "enum": ["pod_css", "storytime"] },
          "triggers": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["idle", "scene-enter", "scroll-progress", "hover", "focus"] }
          },
          "parameterSchemaRef": { "type": "string", "minLength": 1 },
          "sourceFragmentPolicy": { "enum": ["none", "side-effect-free-css-only"] },
          "reducedMotion": { "enum": ["disable", "final-state"] },
          "focusPolicy": { "enum": ["preserve", "not-interactive"] },
          "roleClassifications": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "properties": {
                "target_profile": { "enum": ["story", "website", "social"] },
                "role": { "enum": ["enter", "interaction", "progress", "ambient"] }
              },
              "required": ["target_profile", "role"],
              "additionalProperties": false
            }
          },
          "evidenceRequirements": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": ["animation-metadata", "computed-style", "normalized-progress", "target-geometry", "reduced-motion", "focus-state"]
            }
          }
        },
        "required": ["id", "executor", "triggers", "parameterSchemaRef", "sourceFragmentPolicy", "reducedMotion", "focusPolicy", "roleClassifications", "evidenceRequirements"],
        "additionalProperties": false
      }
    }
  },
  "required": ["contract", "version", "profileDeclarations", "capabilities"],
  "additionalProperties": false
}
